# Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=your_supabase_url_here

# Supabase anon/service-role key for DB access
SUPABASE_KEY=your_supabase_key_here

# Anthropic API key for AI classification and extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SerpAPI key for Google Jobs search results
SERP_API_KEY=your_serp_api_key_here

# n8n instance API key for workflow automation
N8N_API_KEY=your_n8n_api_key_here

# n8n webhook base URL for triggering workflows
N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# Port the fetchers-api server listens on (default: 3000)
PORT=3000
