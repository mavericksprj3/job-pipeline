      }
    },
    {
      "name": "Fetch Himalayas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [304, 912],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.FETCHERS_API_BASE_URL }}/fetch/himalayas?keyword=engineer&country=US",
        "authentication": "none",
        "options": { "timeout": 90000 }
      }
    },
    {
      "name": "Combine All Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [608, 608],
      "parameters": {
        "mode": "append",
        "numberInputs": 5
      }
    },
    {
      "name": "Normalize to job_pool Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, 608],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const STACK_KEYWORDS = [\n  'python', 'javascript', 'typescript', 'react', 'node.js', 'java', 'golang', 'rust',\n  'aws', 'azure', 'gcp', 'devops', 'kubernetes', 'docker', 'sql', 'data science',\n  'machine learning', 'ai', 'ios', 'android', 'frontend', 'backend', 'full stack',\n  'php', 'ruby', 'sales', 'marketing', 'product', 'design', 'support', 'finance', 'hr', 'legal'\n];\n\nfunction inferStackList(job) {\n  if (job.stack) {\n    return String(job.stack).split(',').map(function (s) { return s.trim(); }).filter(Boolean);\n  }\n  const haystack = ((job.title || '') + ' ' + (job.excerpt || job.description || '')).toLowerCase();\n  const match = STACK_KEYWORDS.find(function (k) { return haystack.includes(k); });\n  return match ? [match] : ['Unknown'];\n}\n\nfunction generateUuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {\n    const r = (Math.random() * 16) | 0;\n    const v = c === 'x' ? r : (r & 0x3) | 0x8;\n    return v.toString(16);\n  });\n}\n\nfunction toIso(value) {\n  if (!value) return null;\n  const d = new Date(value);\n  return isNaN(d.getTime()) ? null : d.toISOString();\n}\n\nconst normalized = [];\n\nfor (const item of $input.all()) {\n  const jobs = Array.isArray(item.json && item.json.jobs) ? item.json.jobs : [];\n  for (const raw of jobs) {\n    try {\n      normalized.push({\n        id: generateUuid(),\n        title: (raw && raw.title) || null,\n        company: (raw && raw.company) || null,\n        location: (raw && raw.location) || null,\n        stack: inferStackList(raw || {}),\n        date_posted: toIso(raw && raw.date_posted),\n        link: (raw && raw.link) || null,\n        source: (raw && raw.source) || 'unknown',\n        type: (raw && raw.type) || 'full-time',\n        created_at: new Date().toISOString()\n      });\n    } catch (err) {\n      continue;\n    }\n  }\n}\n\nreturn normalized.map(function (job) { return { json: job }; });\n"
      }
    },
    {
      "name": "Save to Supabase (job_pool)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1200, 608],
      "executeOnce": true,
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/job_pool?on_conflict=link,company",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Prefer", "value": "resolution=merge-duplicates,return=representation" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $input.all().map(i => i.json) }}",
        "options": { "timeout": 60000 }
      },
      "credentials": {
        "httpHeaderAuth": { "name": "Header Auth account" }
      }
    }
  ],
  "connections": {
