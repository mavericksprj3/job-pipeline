      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [304, 608],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.FETCHERS_API_BASE_URL }}/fetch/remoteok",
        "authentication": "none",
